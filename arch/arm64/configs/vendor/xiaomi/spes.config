# Connectivity
CONFIG_NFC_ST21NFC=y
CONFIG_TLS=y
CONFIG_QCA_CLD_WLAN=y
CONFIG_USB_USBNET=y

# Custom
CONFIG_TARGET_PROJECT_K7T=y

# Power Supply
CONFIG_NOPMI_CHARGER=y
CONFIG_BATT_VERIFY_BY_DS28E16=y
CONFIG_MFD_MAX77729=y
CONFIG_CCIC_MAX77729=y
CONFIG_MUIC_MAX77729=y
CONFIG_CHARGER_BQ2589X=y
CONFIG_CHARGER_MAX77729=y
CONFIG_FUELGAUGE_SM5602=y
CONFIG_FUELGAUGE_MAX77729=y
CONFIG_CHARGER_SC8551=y
CONFIG_CHARGER_PD_POLICY=y
CONFIG_TCPC_CLASS=y
CONFIG_DUAL_ROLE_USB_INTF=y
CONFIG_USB_POWER_DELIVERY=y
CONFIG_TCPC_RT1711H=y

# LEDs
# CONFIG_LEDS_AW2016 is not set
# CONFIG_LEDS_QPNP_VIBRATOR_LDO is not set
CONFIG_LEDS_QPNP_VIBRATOR_PWM=y

# Antenna
CONFIG_ANT_CHECK=y
CONFIG_ANT_CHECK_DIV=y

# Fingerprint
# CONFIG_FPR_FPC is not set
CONFIG_INPUT_FINGERPRINT=y
CONFIG_FINGERPRINT_FPC1020=y
CONFIG_FINGERPRINT_GOODIX_FOD=y

# Touchscreen
CONFIG_TOUCHSCREEN_XIAOMI_TOUCHFEATURE=y
# CONFIG_TOUCHSCREEN_NT36XXX is not set
# CONFIG_TOUCHSCREEN_SYNAPTICS_DSX_RMI_DEV is not set

# LPM
CONFIG_LPM_WFI_SCREEN_ON=y
