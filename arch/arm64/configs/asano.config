# Misc
# CONFIG_LOCALVERSION is not set
CONFIG_FAKE_UNAME_5_10=y

# Persistent store
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_RAM=y

# Clang
CONFIG_LTO_CLANG=y

# Filesystems
# CONFIG_SDCARD_FS is not set

# Scheduler
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_BUCKETS_COUNT=20
CONFIG_UCLAMP_TASK_GROUP=y
CONFIG_LITTLE_CPU_MASK=15
CONFIG_BIG_CPU_MASK=240
CONFIG_SCHED_CASS=y
# CONFIG_CPU_FREQ_TIMES is not set
# CONFIG_SCHED_DEBUG is not set
# CONFIG_SCHED_TUNE is not set
# CONFIG_SCHED_WALT is not set
# CONFIG_SCHED_CORE_CTL is not set
# CONFIG_IPC_LOGGING is not set

# IRQ
CONFIG_IRQ_SBALANCE=y
CONFIG_IRQ_SBALANCE_POLL_MSEC=20000
CONFIG_IRQ_SBALANCE_THRESH=1024
CONFIG_SBALANCE_EXCLUDE_CPUS="3,7"

# QCOM
# CONFIG_QTI_CPU_ISOLATE_COOLING_DEVICE is not set


# Memory Management
CONFIG_ANDROID_SIMPLE_LMK=y
# CONFIG_PSI is not set
# CONFIG_MEMCG is not set
